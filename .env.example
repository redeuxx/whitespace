# Application
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# Database (default: SQLite)
DATABASE_URL=sqlite:///whitespace.db

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# File uploads
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE_MB=10
MAX_ATTACHMENTS=10

# Rate limiting (Flask-Limiter syntax)
RATE_LIMIT_PASTE=20 per hour
RATE_LIMIT_SEARCH=60 per hour

# Pagination
PASTES_PER_PAGE=20
